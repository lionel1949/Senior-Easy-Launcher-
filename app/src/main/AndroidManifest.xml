<?xml version="1.0" encoding="utf-8"?>
<!--
  ============================================================
  老年桌面 (OldMan Launcher) — AndroidManifest.xml

  关键配置说明:
  1. 注册为桌面应用 (CATEGORY_HOME)，可替换系统 Launcher
  2. 固定竖屏，禁止旋转
  3. 请求 CALL_PHONE 权限（一键拨号）
  4. 声明 QUERY_ALL_PACKAGES（扫描已安装App，Android 11+ 需要）

  国产ROM兼容性提示:
  - 小米 (MIUI): 设置→应用管理→默认应用→桌面→选择"老年桌面"
  - 华为 (EMUI): 设置→应用→默认应用→桌面→选择"老年桌面"
  - OPPO (ColorOS): 设置→应用管理→默认应用管理→桌面→选择"老年桌面"
  - vivo (OriginOS): 设置→应用与权限→默认应用→桌面→选择"老年桌面"
  ============================================================
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 拨打电话权限（一键拨号） -->
    <uses-permission android:name="android.permission.CALL_PHONE" />

    <!-- 扫描已安装应用列表 (Android 11+ 必需，Launcher 场景属于合法用途) -->
    <uses-permission
        android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <application
        android:name=".OldManApp"
        android:allowBackup="true"
        android:supportsRtl="true"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        tools:targetApi="34">

        <!--
          MainActivity 配置说明:
          - singleTask: 确保桌面只有一个实例（按 Home 键回到已有桌面）
          - portrait: 锁定竖屏，避免老人误触旋转
          - 全屏主题在 Theme 中配置
        -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.OldMan">

            <!--
              intent-filter #1: 桌面启动器
              CATEGORY_HOME + CATEGORY_DEFAULT = 可被选为系统默认桌面
            -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>

            <!--
              intent-filter #2: 常规启动器入口
              让本 App 也出现在应用抽屉中，方便打开设置等功能
            -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>
    </application>

</manifest>
